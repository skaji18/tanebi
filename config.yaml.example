# TANEBI設定ファイル
# design.md / docs/learning-engine.md 参照

tanebi:
  version: "1.0"

  # === パス設定 ===
  paths:
    work_dir: "work"                      # タスクワークスペース（work/cmd_NNN/）
    knowledge_dir: "knowledge"            # 知識ベースルートディレクトリ
    signals_dir: "knowledge/signals"      # 生シグナル蓄積（タスク完了後に書き込まれる）
    learned_dir: "knowledge/learned"      # 蒸留済みパターン（蒸留エンジンが生成）

  # === 実行設定 ===
  execution:
    max_parallel_workers: 5               # 並列実行するワーカーの最大数
    worker_max_turns: 30                  # ワーカー1タスクあたりの最大ターン数（超過すると強制終了）
    default_model: "claude-sonnet-4-6"    # 使用する Claude モデル ID
    claude_native: true                   # true = Claude Code subprocess モード / false = Anthropic API モード
    timeout: 300                          # ワーカータイムアウト（秒）

  # === 学習エンジン設定 ===
  learning:
    signal:
      auto_detect: true
      retention_days: 90
    distillation:
      min_signals: 3
      min_confidence: 0.7
      auto_trigger: true
    injection:
      max_approach: 5
      max_avoid: 5
      max_decompose: 3
      max_tooling: 3

  # === チェックポイント設定 ===
  checkpoint:
    mode: auto              # always / auto / never
    max_rounds: 3           # 最大ループ回数（デフォルト3）
    verdict_policy: any_fail  # any_fail / majority / all_fail
