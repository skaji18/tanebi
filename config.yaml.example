# TANEBI設定ファイル
# design.md / docs/learning-engine.md 参照

tanebi:
  version: "1.0"

  # === パス設定 ===
  paths:
    work_dir: "work"
    knowledge_dir: "knowledge"
    signals_dir: "knowledge/signals"
    learned_dir: "knowledge/learned"
    episode_dir: "knowledge/episodes"

  # === 実行設定 ===
  execution:
    max_parallel_workers: 5
    worker_max_turns: 30
    default_model: "claude-sonnet-4-6"
    claude_native: true
    timeout: 300

  # === 学習エンジン設定 ===
  learning:
    min_signals_for_distillation: 5   # 蒸留に必要な最小シグナル数
    max_patterns_per_domain: 100      # ドメイン毎の最大パターン数
    routing:
      weights:
        quality_score: 0.35
        completion_rate: 0.30
        efficiency: 0.20
        growth_rate: 0.15
      window: 20                      # routing_score 計算のスライディングウィンドウ

  # === チェックポイント設定 ===
  checkpoint:
    mode: auto              # always / auto / never
    max_rounds: 3           # 最大ループ回数（デフォルト3）
    verdict_policy: any_fail  # any_fail / majority / all_fail
